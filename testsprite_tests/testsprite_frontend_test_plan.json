[
  {
    "id": "TC001",
    "title": "Login with valid email/password redirects to dashboard",
    "description": "Verifies a user can sign in via the authentication page and reach the protected dashboard.",
    "category": "User Authentication",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /auth"
      },
      {
        "type": "assertion",
        "description": "Verify page title contains \"Auth\""
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on \"Sign in\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Dashboard\" is visible"
      }
    ]
  },
  {
    "id": "TC002",
    "title": "Login with invalid credentials shows an authentication error",
    "description": "Verifies invalid email/password is rejected and an error message is shown on the auth page.",
    "category": "User Authentication",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /auth"
      },
      {
        "type": "action",
        "description": "Type \"not.a.user@example.invalid\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"WrongPassword123!\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on \"Sign in\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/auth\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Invalid\" is visible"
      }
    ]
  },
